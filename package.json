{
  "name": "portfolio-lab-spa",
  "version": "1.0.0",
  "private": true,
  "description": "SPA de gestion de portfolio en Vanilla JavaScript avec json-server.",
  "scripts": {
    "api": "json-server --watch db.json --port 3000",
    "build:css": "tailwindcss -i ./src/input.css -o ./styles.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./styles.css --watch"
  },
  "devDependencies": {
    "json-server": "^1.0.0-beta.3",
    "tailwindcss": "^3.4.17"
  }
}
